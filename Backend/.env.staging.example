# Backend staging example for direct PM2/node runs.
# If you deploy with Docker compose, use the root .env.staging.example instead.

APP_ENV=staging
NODE_ENV=production
PORT=8081
ENABLE_BACKGROUND_JOBS=false

FRONTEND_URL=https://staging.scalor.net
BACKEND_URL=https://api-staging.scalor.net
PUBLIC_BACKEND_URL=https://api-staging.scalor.net
CORS_ORIGINS=https://staging.scalor.net,https://api-staging.scalor.net

# Must be separate from production.
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/plateforme_staging?retryWrites=true&w=majority

# Must be different from production.
ECOM_JWT_SECRET=replace_with_a_different_staging_secret
SESSION_SECRET=replace_with_a_different_staging_session_secret
DATA_ENCRYPTION_KEY=replace_with_a_32_byte_staging_encryption_secret

# Optional integrations. Use test accounts/keys when possible.
SMTP_HOST=mail.scalor.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@scalor.net
EMAIL_FROM_NAME=Scalor Staging
EMAIL_REPLY_TO=support@scalor.net
ADMIN_EMAIL=support@scalor.net

OTP_EMAIL_PROVIDER=resend
OTP_EMAIL_FROM="Scalor Staging <auth@infomania.store>"
OTP_REPLY_TO=support@scalor.net
RESEND_API_KEY=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=scalor-staging
R2_PUBLIC_URL=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@scalor.net

OPENAI_API_KEY=
GROQ_API_KEY=
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_MODEL_PATH=/gpt-5-2/v1/chat/completions
KIE_REASONING_EFFORT=low
KIE_TIMEOUT_MS=120000
