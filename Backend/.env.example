# ─── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/plateforme?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────
ECOM_JWT_SECRET=your_jwt_secret_here

# ─── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here

# ─── Cloudflare R2 (file storage) ─────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Cloudflare Images (product photos) ────────────────────
# Get from: https://dash.cloudflare.com → Images → API Tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ─── Web Push (VAPID keys) ────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# IMPORTANT: Keys must be in Base64URL format (A-Z, a-z, 0-9, -, _)
# NO padding (=), NO + or / characters
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@example.com

# ─── WhatsApp Green API ───────────────────────────────────
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Shopify ───────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=https://api.scalor.net/api/ecom/shopify/callback
# Webhook secret (from Shopify → Settings → Notifications → Webhooks)
SHOPIFY_WEBHOOK_SECRET=

# ─── Scrape.do (Alibaba scraping) ──────────────────────────
# Get from: https://scrape.do/
SCRAPE_DO_TOKEN=

# ─── Google Imagen API (NanoBanana) ────────────────────────
# Génération d'images produit avec Google Imagen 3 (dernier modèle)
# Get from: https://console.cloud.google.com/apis/credentials
NANOBANANA_API_KEY=AIzaSyBMhUariTC0fSNx1b9mKGkXzcslGnyWDpk

# ─── Groq API (LLM pour génération contenu) ────────────────
GROQ_API_KEY=

# ─── Server ───────────────────────────────────────────────
PORT=8080
NODE_ENV=production
