# ─── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/plateforme?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────
ECOM_JWT_SECRET=your_jwt_secret_here

# ─── Google OAuth ──────────────────────────────────────────
# Optional: comma-separated list. Useful when prod/staging/local use different web client IDs.
GOOGLE_CLIENT_IDS=
GOOGLE_CLIENT_ID=your_google_client_id_here

# ─── Cloudflare R2 (file storage) ─────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Cloudflare Images (product photos) ────────────────────
# Get from: https://dash.cloudflare.com → Images → API Tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ─── Web Push (VAPID keys) ────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# IMPORTANT: Keys must be in Base64URL format (A-Z, a-z, 0-9, -, _)
# NO padding (=), NO + or / characters
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@example.com

# ─── WhatsApp Green API ───────────────────────────────────
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=

# ─── KIE API (Gemini via OpenAI-compatible endpoint) ──────
# WhatsApp Rita chat will use this provider first.
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_MODEL_PATH=/gpt-5-2/v1/chat/completions
KIE_REASONING_EFFORT=low
KIE_TIMEOUT_MS=120000

# ─── Shopify ───────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=https://api.scalor.net/api/ecom/shopify/callback
# Webhook secret (from Shopify → Settings → Notifications → Webhooks)
SHOPIFY_WEBHOOK_SECRET=

# ─── Scrape.do (Alibaba scraping) ──────────────────────────
# Get from: https://scrape.do/
SCRAPE_DO_TOKEN=

# ─── Google Gemini (Nano Banana 2) — fallback génération images ─────────
# Utilisé comme filet de secours quand Kie.ai (NANOBANANA_PRO_API_KEY) échoue
# sur la génération de visuels de page produit (poster, infographics).
# Modèle : gemini-3-pro-image-preview (Nano Banana Pro).
# Alternatives : gemini-3.1-flash-image-preview (Nano Banana 2), gemini-2.5-flash-image (v1).
# Get from: https://aistudio.google.com/app/apikey
# IMPORTANT: ne JAMAIS commiter la vraie clé — laisser vide ici et la définir
# dans les variables d'env Railway/Vercel.
GEMINI_API_KEY=
# Alias historique conservé pour rétro-compatibilité (geminiProductExtractor.js)
# Si GEMINI_API_KEY est défini, il a la priorité.
NANOBANANA_API_KEY=
# (Optionnel) override du modèle Gemini image
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ─── Groq API (LLM pour génération contenu) ────────────────
GROQ_API_KEY=

# ─── Server ───────────────────────────────────────────────
PORT=8080
NODE_ENV=production
