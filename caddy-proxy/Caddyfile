{
	on_demand_tls {
		ask {$CADDY_ASK_URL:https://ecomcookpit-production-0ec4.up.railway.app/api/caddy/check-domain}
	}
	email {$ACME_EMAIL:admin@scalor.net}
}

:443 {
	tls {
		on_demand
	}
	reverse_proxy {$RAILWAY_BACKEND:https://ecomcookpit-production-0ec4.up.railway.app} {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
		header_up X-Caddy-Proxy "true"
		transport http {
			dial_timeout 10s
			response_header_timeout 30s
		}
	}
}

:80 {
	redir https://{host}{uri} permanent
}
