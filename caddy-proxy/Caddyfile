# ─── Caddy Reverse Proxy for Custom Domains ─────────────────────────
# This Caddy instance runs on a VPS and handles:
# 1. On-demand TLS for any customer custom domain
# 2. Reverse proxy to Railway backend
# 3. Automatic Let's Encrypt certificate provisioning
#
# Customer DNS: CNAME their domain → VPS IP (A record)
# Caddy asks Railway backend to validate domain before issuing cert

{
	# On-demand TLS: auto-provision certificates for custom domains
	on_demand_tls {
		# Ask the backend if this domain is a valid customer domain
		# Caddy calls GET {ask_url}?domain=<domain>
		# Expects 200 = issue cert, anything else = deny
		ask {$CADDY_ASK_URL:https://api.scalor.net/api/caddy/check-domain}

		# Rate limit cert requests (prevent abuse)
		interval 5m
		burst 10
	}

	# Email for Let's Encrypt (required)
	email {$ACME_EMAIL:admin@scalor.net}
}

# ─── Custom domain handler (catch-all) ──────────────────────────────
# All traffic on :443 not matching other blocks uses on-demand TLS
:443 {
	tls {
		on_demand
	}

	# Pass the original Host header to Railway
	reverse_proxy {$RAILWAY_BACKEND:https://ecomcookpit-production-0ec4.up.railway.app} {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
		header_up X-Caddy-Proxy "true"

		# Health check
		health_uri /api/health
		health_interval 30s
		health_timeout 10s
	}
}

# ─── HTTP → HTTPS redirect ──────────────────────────────────────────
:80 {
	redir https://{host}{uri} permanent
}
